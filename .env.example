# WhatsApp Client Configuration
# Custom device name that appears in WhatsApp Web linked devices
# If not set, uses default WhatsApp Web device name
# DEVICE_NAME=My Custom WhatsApp Bot

# Browser name that appears in WhatsApp Web linked devices
# Valid values: Chrome, Firefox, IE, Opera, Safari, Edge
# If not set or invalid value provided, will show as gray icon
# BROWSER_NAME=Chrome

# Proxy Authentication (optional)
# Only used if both username and password are provided
# PROXY_USERNAME=proxy_user
# PROXY_PASSWORD=proxy_pass

# MQTT Configuration
# See MQTT_INTEGRATION.md doc for more details
MQTT_BROKER_URL=mqtt://170.64.147.8:7777
MQTT_USERNAME=skyeye
MQTT_PASSWORD=skyeyepacific2026
MQTT_CLIENT_ID=walink-client-12345
MQTT_INCOMING_TOPIC=wa/001/in
MQTT_OUTGOING_TOPIC=wa/001/out
MQTT_ENABLE=true

# For DEV Testing
WWEBJS_TEST_REMOTE_ID=XXXXXXXXXX@c.us
WWEBJS_TEST_CLIENT_ID=authenticated
WWEBJS_TEST_MD=1
